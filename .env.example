# IQ Option credentials
IQ_EMAIL=your_email@example.com
IQ_PASSWORD=your_password

# Account type: PRACTICE or REAL
IQ_ACCOUNT=PRACTICE

# Assets (comma-separated)
IQ_ASSETS=EURUSD,GBPUSD,AUDUSD,USDJPY,EURGBP

# Timeframe in seconds: 60=M1, 300=M5, 900=M15, 1800=M30
IQ_TIMEFRAME=300

# Trade amount per order (USD)
IQ_AMOUNT=1.0

# Minimum confidence score to execute trade (0-100)
IQ_CONFIDENCE=70.0

# Max consecutive losses before pausing
IQ_MAX_LOSSES=3

# Telegram Bot (get from @BotFather)
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here
