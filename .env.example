# ── IQ Option credentials ──
IQ_EMAIL=your_email@example.com
IQ_PASSWORD=your_password

# Account type: PRACTICE (เงินทดลอง) or REAL (เงินจริง)
IQ_ACCOUNT=PRACTICE

# Assets: บอทเลือกคู่ forex จริงที่เปิดอยู่อัตโนมัติ เรียงตาม payout สูงสุด
# (ไม่เทรด OTC เด็ดขาด — คู่จริงเปิดเฉพาะวันจันทร์-ศุกร์ เสาร์-อาทิตย์บอทจะรอ)
IQ_ASSETS=AUTO
IQ_MAX_ASSETS=12

# Timeframe (วินาที): 60=M1, 300=M5, 900=M15, 1800=M30
IQ_TIMEFRAME=300

# เงินต่อไม้ (ฐาน Martingale) — ปรับละเอียดเพิ่มได้ในแท็บตั้งค่าบนแดชบอร์ด
IQ_AMOUNT=50.0

# confidence ขั้นต่ำที่จะเข้าออเดอร์ (0-100)
IQ_CONFIDENCE=70.0

# แพ้ติดกันสูงสุดก่อนหยุดอัตโนมัติ
IQ_MAX_LOSSES=4

# จำนวนไม้เปิดพร้อมกันสูงสุด (1-3, แต่ละคู่ทบ Martingale แยกกัน)
IQ_MAX_OPEN=3

# ขีดจำกัด/วัน
IQ_MAX_DAY_TRADES=20
IQ_DAILY_TARGET=200.0
IQ_DAILY_LOSS_LIMIT=0

# ── Telegram Bot (ขอ token จาก @BotFather, chat_id จาก @userinfobot) ──
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# ── Dashboard HTTP server ──
# Port for the dashboard HTTP server (served to Cloudflare Tunnel)
DASHBOARD_HTTP_PORT=8766
# WS server port is hardcoded at 8765 in main.py — do not change without updating cloudflared config

# หมายเหตุ: ค่าหลายตัว (เงินต่อไม้, Martingale, expiry, ขีดจำกัด) ถ้าเคยบันทึกจากแดชบอร์ด
# จะถูกเก็บใน data/config.json และมีผลทับค่าใน .env นี้
